#!/bin/bash

BACKUP_DIR="/backups"
DATE=$(date +%F)

BACKUP_FILE="$BACKUP_DIR/apache_backup_$DATE.tar.gz"
LOG_FILE="$BACKUP_DIR/apache_backup_log.txt"

tar -czvf $BACKUP_FILE /etc/httpd /var/www/html >> $LOG_FILE 2>&1

echo "Backup created: $BACKUP_FILE" >> $LOG_FILE

echo "Verifying backup contents:" >> $LOG_FILE
tar -tzf $BACKUP_FILE >> $LOG_FILE

echo "------------------------------------" >> $LOG_FILE
